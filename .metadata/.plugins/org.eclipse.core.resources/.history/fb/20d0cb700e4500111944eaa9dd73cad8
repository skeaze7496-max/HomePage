package com.collection;
import java.util.*;
public class CollectEx04 {

	private static final String[] Colors = { "검정", "노랑", "초록", "파랑", "빨강", "연두" };
	
	public static void main(String[] args) {
		
		Queue<String> qu = new LinkedList<>();
		
		for(String str : Colors) {
			qu.offer(str);
		}
		
		
	}

}

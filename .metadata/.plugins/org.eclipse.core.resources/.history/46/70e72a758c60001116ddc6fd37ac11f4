<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ page import="com.memberone.*" %>
<jsp:useBean id="dao" class="com.memberone.StudentDAO"></jsp:useBean>

<%
    // 1. 세션에서 현재 로그인한 ID를 가져옴
    String loginID = (String)session.getAttribute("loginID");
	String loginPW = (String)session.getAttribute("loginPW");

    // 2. 로그인 안 되어 있으면 login.jsp로 돌려보냄
    if(loginID == null) {
        response.sendRedirect("login.jsp");
        return;
    }
 	// 3. DAO 메서드 호출 (result: 1-성공, 0-비번불일치)
    int result = dao.deleteMember(loginID, loginPW);
    // 4. DAO를 사용하여 DB에서 삭제
    dao.deleteMember(loginID,loginPW);

    // 5. 세션 무효화 (로그아웃 처리)
    session.invalidate();
%>

<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>회원탈퇴</title>
</head>
<body>
   <script type="text/javascript">
        <% if(result == 1) { %>
            // 탈퇴 성공 시 세션 삭제
            <% session.invalidate(); %>
            alert("회원 탈퇴가 완료되었습니다.");
            location.href = "login.jsp";
        <% } else { %>
            // 비밀번호 불일치 등 실패 시
            alert("비밀번호가 일치하지 않습니다.");
            history.back(); // 입력 페이지로 되돌림
        <% } %>
    </script>
</body>
</html>
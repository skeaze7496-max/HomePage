<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ page import="com.boardone.*" %>
<%@ include file="view/color.jsp" %>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<link href="style.css" rel="stylesheet" type="text/css">
<script type="text/javascript" src="script.js"></script>
<title></title>
</head>
<%
	int num = Integer.parseInt(request.getParameter("num"));
	String pageNum = request.getParameter("pageNum");
	
	try {
		BoardDAO dbPro = BoardDAO.getInstance();
		BoardVO article = dbPro.updateGetArticle(num);
%>
<body bgcolor="<%=bodyback_c %>">
<div align="center"><b>글 수정</b><br>
<form action="updateProc.jsp?pageNum=<%=pageNum %>" method="post" name="updateForm"
name="updateForm" onsubmit="return writeSave()">
<table width="400" border="1" cellpadding="0" 
cellspacing="0" align="center" bgcolor="<%=bodyback_c %>">

	<tr>
		<td width="70" bgcolor="<%=value_c%>" align="center">이름</td>
		<td align="left" width="330">
			<input type="text" size="10" maxlength="10" name="writer" value="<%=article.getWriter()%>">
			<input type="hidden" name="num" value="<%=article.getNum()%>">
		</td>	
	</tr>
	<tr>
		<td width="70" bgcolor="<%=value_c%>" align="center">제목</td>
		<td align="left" width="330">
			<input type="text" size="40" maxlength="50" name="subject" value="<%=article.getSubject()%>">
			<input type="hidden" name="num" value="<%=article.getNum()%>">
		</td>	
	</tr>
	<tr>
		<td width="70" bgcolor="<%=value_c%>" align="center">이메일</td>
		<td align="left" width="330">
			<input type="text" size="40" maxlength="50" name="email" value="<%=article.getEmail()%>">
			<input type="text" name="email" value="<%=article.getEmail()%>">
		</td>	
	</tr>
	<tr>
		<td width="70" bgcolor="<%=value_c%>" align="center">내용</td>
		<td align="left" width="330">
			<textarea rows="13" cols="40" name="content"<%=article.getContent() %>></textarea>
		</td>	
	</tr>
	<tr>
		<td width="70" bgcolor="<%=value_c%>" align="center">비밀번호</td>
		<td align="left" width="330">
			<input type="password" size="8" maxlength="12" name="pass" value="<%=article.getPass()%>">
			<input type="text" name="email" value="<%=article.getEmail()%>">
		</td>	
	</tr>
	
</table>
</form>
</div>
<% 
	}catch(Exception e) {e.printStackTrace();}
%>
</body>
</html>
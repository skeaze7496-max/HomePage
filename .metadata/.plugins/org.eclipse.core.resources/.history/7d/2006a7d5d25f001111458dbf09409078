<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
         xmlns="http://xmlns.jcp.org/xml/ns/javaee" 
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" 
         id="WebApp_ID" 
         version="4.0">

  <display-name>servletProject</display-name>

  <!-- 1. 리스너 설정 (규격상 제일 위쪽 부근에 와야 함) -->
  <listener>
    <listener-class>com.test.ContextListenerImpl</listener-class>
  </listener>
  
  <!-- 2. 컨텍스트 파라미터 -->
  <context-param>
    <param-name>company</param-name>
    <param-value>Globalin</param-value>
  </context-param>
  <context-param>
    <param-name>manager</param-name>
    <param-value>JungSub Kim</param-value>
  </context-param>

  <!-- 3. 서블릿 등록 -->
  <servlet>
    <servlet-name>InitParam</servlet-name>
    <servlet-class>com.sample.InitParam</servlet-class>
    <init-param>
      <param-name>tel</param-name>
      <param-value>010-1111-2222</param-value>
    </init-param>
    <init-param>
      <param-name>email</param-name>
      <param-value>globalin@naver.com</param-value>
    </init-param>
  </servlet>

  <!-- 4. 서블릿 매핑 -->
  <servlet-mapping>
    <servlet-name>InitParam</servlet-name>
    <url-pattern>/InitParam</url-pattern>
  </servlet-mapping>
  
  <servlet>
  	<servlet-name>VisitList</servlet-name>
  	<servlet-class>com.bbs.VisitList</servlet-class>
  </servlet>
  
    <servlet-mapping>
    <servlet-name>VisitList</servlet-name>
    <url-pattern>/VisitList</url-pattern>
  </servlet-mapping>
  
  
    <servlet>
  	<servlet-name>VisitInsert</servlet-name>
  	<servlet-class>com.bbs.VisitInsert</servlet-class>
  </servlet>
  
    <servlet-mapping>
    <servlet-name>VisitInsert</servlet-name>
    <url-pattern>/VisitInsert</url-pattern>
  </servlet-mapping>
  
   <servlet>
  	<servlet-name>Login</servlet-name>
  	<servlet-class>com.login.Login</servlet-class>
  </servlet>
  
    <servlet-mapping>
    <servlet-name>Login</servlet-name>
    <url-pattern>/Login</url-pattern>
  </servlet-mapping>
  
   <servlet>
  	<servlet-name>LoginCheck</servlet-name>
  	<servlet-class>com.login.LoginCheck</servlet-class>
  </servlet>
  
    <servlet-mapping>
    <servlet-name>LoginCheck</servlet-name>
    <url-pattern>/LoginCheck</url-pattern>
  </servlet-mapping>
  	
	<servlet>
  		<servlet-name>Logout</servlet-name>
  		<servlet-class>com.login.Logout</servlet-class>
  	</servlet>
  
   <servlet-mapping>
    <servlet-name>Logout</servlet-name>
    <url-pattern>/Logout.do</url-pattern>
  </servlet-mapping>  
  	

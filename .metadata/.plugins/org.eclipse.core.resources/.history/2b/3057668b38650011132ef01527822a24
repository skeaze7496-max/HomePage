    public static BoardDAO getInstance() {
        // 첫 번째 null 체크 (성능을 위해)
        if (instance == null) {
            // 인스턴스가 없을 때만 동기화 블록 진입
            synchronized (BoardDAO.class) {
                // 두 번째 null 체크 (멀티스레드 환경 대비)
                if (instance == null) {
                    instance = new BoardDAO();
                }
            }
        }
        return instance;
    }
